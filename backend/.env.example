DATABASE_URL=
# Anthropic API key — used by the puzzle generation pipeline (group_generator.py).
# Get yours at https://console.anthropic.com → API Keys.
# NEVER commit your real key to version control.
ANTHROPIC_API_KEY=
SUPABASE_URL=https://[SUPABASE_PROJECT_ID].supabase.co
SUPABASE_JWT_SECRET=
# service_role key (from Supabase dashboard → Settings → API → service_role).
# Used by puzzle_pool_service to bypass Row Level Security for server-side ops.
# NEVER expose this key to the frontend or commit it to version control.
SUPABASE_KEY=
# Comma-separated list of email addresses allowed to access /admin/* endpoints.
# Example: ADMIN_EMAILS=you@example.com,other@example.com
ADMIN_EMAILS=
# Comma-separated list of allowed CORS origins for the Flask API.
# In development this defaults to http://localhost:5173 (Vite default).
# In production, set this to your deployed frontend URL.
# Example: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173